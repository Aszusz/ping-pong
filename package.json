{
  "name": "ping-pong",
  "private": true,
  "type": "module",
  "scripts": {
    "docker:up": "docker compose --env-file .env.local up -d",
    "docker:down": "docker compose --env-file .env.local down",
    "docker:reset": "docker compose --env-file .env.local down -v",
    "db:push": "dotenv -e .env.local -- pnpm --filter @ping-pong/db run push",
    "web:dev": "pnpm --filter @ping-pong/web run dev",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "pnpm -r run typecheck",
    "qual": "pnpm format && pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  }
}
